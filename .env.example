# API Configuration
VITE_API_BASE_URL=http://localhost:5000/api
VITE_API_TIMEOUT=10000

# Google Maps API
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# File Upload Limits
VITE_MAX_AUDIO_SIZE_MB=5
VITE_MAX_DOCUMENT_SIZE_MB=10

# Contact Information (Admin Configurable)
VITE_CONTACT_PHONE=+91-XXXXXXXXXX
VITE_CONTACT_EMAIL=info@agarwalacademy.in
VITE_CONTACT_ADDRESS=South Delhi, India

# Email Configuration for Inquiry Notifications
VITE_INQUIRY_EMAIL=agarwalacademy29@gmail.com
VITE_ADMIN_EMAIL=agarwalacademy29@gmail.com

# Admin Access
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=admin123

# Firebase Configuration (for OTP Verification)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Feature Flags
VITE_ENABLE_WHATSAPP=false
VITE_ENABLE_AI_FEATURES=false
